# MicroSaaS Factory Environment Variables
# Copy to .env and fill in values. Never commit secrets.

# Database (SQLite, required)
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET="change-me-to-a-random-secret"

# LLM Providers (all optional — DummyProvider works without any keys)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default LLM provider: "dummy" | "gemini" | "openai" | "anthropic"
# If GEMINI_API_KEY is set and this is empty, defaults to "gemini"
DEFAULT_LLM_PROVIDER=

# Demo mode (true = allow unauthenticated use with shared server key)
DEMO_MODE=true

# Rate limiting
DEMO_DAILY_GLOBAL_LIMIT=200
DEMO_DAILY_PER_IP_LIMIT=20

# IP hashing salt for rate limiter (change in production)
DEMO_IP_SALT=microsaas-change-this-salt

# LLM cache TTL in hours (default 168 = 1 week)
LLM_CACHE_TTL_HOURS=168

# Site URL for OG images and sitemap
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Git SHA for build info
NEXT_PUBLIC_GIT_SHA=
