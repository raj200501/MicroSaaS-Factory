{
  "name": "microsaas-factory",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "postinstall": "pnpm --filter @microsaas/db exec prisma generate || true",
    "db:push": "pnpm --filter @microsaas/db exec prisma db push",
    "db:seed": "pnpm --filter @microsaas/db exec tsx seed.ts",
    "db:generate": "pnpm --filter @microsaas/db exec prisma generate",
    "generate:launch-kit": "tsx scripts/generate-launch-kit.ts"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "turbo": "latest",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@8.0.0",
  "dependencies": {
    "@types/marked": "^6.0.0",
    "marked": "^17.0.4",
    "tsx": "^4.7.1"
  }
}